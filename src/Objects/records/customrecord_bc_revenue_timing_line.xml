<?xml version="1.0" encoding="UTF-8"?>
<customrecordtype scriptid="customrecord_bc_revenue_timing_line">
  <name>BC Revenue Timing Line</name>
  <description>Time-phased revenue (customer payment) forecast per contract. Base Contract + CO lines share this record type. No GL impact.</description>
  <includename>F</includename>
  <isinactive>F</isinactive>
  <isordered>F</isordered>
  <showcreateddate>T</showcreateddate>
  <showlastmodified>T</showlastmodified>
  <showlastmodifiedby>T</showlastmodifiedby>
  <shownotes>F</shownotes>
  <allowattachments>F</allowattachments>
  <allowinlineediting>T</allowinlineediting>
  <allowinlinedeleting>T</allowinlinedeleting>
  <allowquicksearch>F</allowquicksearch>
  <enablemailmerge>F</enablemailmerge>
  <nopermissionrequired>F</nopermissionrequired>
  <usepermissions>T</usepermissions>
  <customrecordcustomfields>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_transaction">
      <label>Contract (Sales Order)</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>-30</selectrecordtype>
      <description>The Sales Order (contract) this timing relates to</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_project">
      <label>Project</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customrecord_cseg_bc_project]</selectrecordtype>
      <description>BlueCollar Project (denormalized)</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_period_date">
      <label>Period Date</label>
      <fieldtype>DATE</fieldtype>
      <description>When this revenue payment is expected (Cash Flow) or recognized (Accrual)</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_percentage">
      <label>Percentage</label>
      <fieldtype>PERCENT</fieldtype>
      <description>Percentage of contract value attributed to this period</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_amount">
      <label>Amount</label>
      <fieldtype>CURRENCY</fieldtype>
      <description>Dollar amount expected this period</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_cumulative_pct">
      <label>Cumulative %</label>
      <fieldtype>PERCENT</fieldtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_cumulative_amt">
      <label>Cumulative Amount</label>
      <fieldtype>CURRENCY</fieldtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_status">
      <label>Status</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customlist_bc_ctl_status]</selectrecordtype>
      <description>Forecasted, Received, or Overdue</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_label">
      <label>Label / Note</label>
      <fieldtype>TEXT</fieldtype>
      <description>Optional description (e.g., Progress Payment #1, Retainage Release)</description>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_source">
      <label>Source</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customlist_bc_ctl_source]</selectrecordtype>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_source_group">
      <label>Source Group</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customlist_bc_ctl_source_group]</selectrecordtype>
      <description>Base Contract or Change Order</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_timing_type">
      <label>Timing Type</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customlist_bc_ctl_timing_type]</selectrecordtype>
      <description>Cash Flow or Accrual</description>
      <ismandatory>T</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_source_template">
      <label>Source Template</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customrecord_bc_cost_timing_template]</selectrecordtype>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_change_order">
      <label>Related Change Order</label>
      <fieldtype>SELECT</fieldtype>
      <selectrecordtype>[scriptid=customrecord_bc_change_req]</selectrecordtype>
      <description>Set when line originates from CO approval</description>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
    </customrecordcustomfield>
    <customrecordcustomfield scriptid="custrecord_bc_rtl_needs_recalc">
      <label>Needs Recalculation</label>
      <fieldtype>CHECKBOX</fieldtype>
      <description>Flagged when CO approval changes contract value</description>
      <ismandatory>F</ismandatory>
      <displaytype>NORMAL</displaytype>
      <defaultvalue>F</defaultvalue>
    </customrecordcustomfield>
  </customrecordcustomfields>
</customrecordtype>
